# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  —  Copy to .env and fill in your values
#  NEVER commit .env to git (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq API Key (REQUIRED) ───────────────────────────────────────────────────
# Get a FREE key at: https://console.groq.com
# Regenerate your key immediately if it was ever exposed publicly.
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_NEW_KEY

# ── Groq Model ────────────────────────────────────────────────────────────────
# Recommended options:
#   llama-3.3-70b-versatile   ← best quality  (default)
#   llama-3.1-8b-instant      ← fastest / lowest cost
#   mixtral-8x7b-32768        ← good balance
GROQ_MODEL=llama-3.3-70b-versatile

# ── Send Mode ─────────────────────────────────────────────────────────────────
# "dry_run" → emails generated & logged but NOT sent  (safe default)
# "live"    → emails actually dispatched
SEND_MODE=dry_run

# ── Email Provider ────────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp      # smtp | sendgrid

# ── Sender Identity (set SPF/DKIM/DMARC for this domain before going live) ───
SENDER_EMAIL=ar@acme.in
SENDER_NAME=Accounts Receivable, Acme Finance Pvt Ltd
SENDER_DOMAIN=acme.in

# ── SMTP Settings ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password        # Gmail App Password (not your main password)

# ── SendGrid (alternative to SMTP) ───────────────────────────────────────────
SENDGRID_API_KEY=SG.REPLACE_WITH_YOUR_KEY

# ── Data Source ───────────────────────────────────────────────────────────────
DATA_SOURCE=sample_data.csv

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULE_HOUR=9
SCHEDULE_MIN=0
SCHEDULE_DAYS=mon-fri

# ── Safety ────────────────────────────────────────────────────────────────────
BATCH_SEND_LIMIT=50      # max emails per run (circuit breaker)
